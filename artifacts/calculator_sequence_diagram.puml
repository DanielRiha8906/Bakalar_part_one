@startuml calculator_sequence_diagram

actor User
participant "run_interactive()" as Loop
participant "Calculator" as Calc

User -> Loop ** : <<create>>
Loop -> Calc ** : <<create>>

Loop --> User : print welcome & instructions

loop until user quits
    Loop --> User : prompt: Operation?
    User -> Loop : operation (or "quit"/"exit")

    alt user typed quit or exit
        Loop --> User : print "Goodbye!"
        Loop -> Loop : break
    else unknown operation
        Loop --> User : print error, retry loop
    else valid operation
        Loop --> User : prompt: First number?
        User -> Loop : number a

        alt non-numeric input
            Loop --> User : print "Invalid input", retry loop
        else numeric
            Loop --> User : prompt: Second number?
            User -> Loop : number b

            alt operation is divide and b == 0
                Loop --> User : print "Error: Cannot divide by zero"
            else normal calculation
                Loop -> Calc : add/subtract/multiply/divide(a, b)
                Calc --> Loop : result
                Loop --> User : print "Result: <result>"
            end

            Loop --> User : prompt: Another calculation? (yes/no)
            User -> Loop : answer

            alt answer is not yes or y
                Loop --> User : print "Goodbye!"
                Loop -> Loop : break
            end
        end
    end
end

Loop -> Calc !! : <<destroy>>
Loop -> Loop !! : <<destroy>>

@enduml
